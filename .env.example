# ─────────────────────────────────────────────────────────────
# 30praum — environment template
# Copie para .env.local e preencha. Nunca commite .env.local.
# ─────────────────────────────────────────────────────────────

# Pública: URL base do site (usada em metadata + sitemap)
NEXT_PUBLIC_SITE_URL=https://30praum.com

# Pública: URL pública do servidor (usada pelo Payload pra links absolutos)
NEXT_PUBLIC_SERVER_URL=https://30praum.com

# ─────────────────────────────────────────────────────────────
# Supabase Postgres (Payload CMS)
# ─────────────────────────────────────────────────────────────
# Connection string da role postgres do projeto Supabase.
# Use ?sslmode=no-verify pra contornar self-signed cert no driver pg.
DATABASE_URI=

# Secret do Payload — gere com: openssl rand -hex 32
PAYLOAD_SECRET=

# ─────────────────────────────────────────────────────────────
# Shopify Storefront API — quando preenchidos, o site sai do modo mock.
# Obter em: Admin Shopify → Apps → Develop apps → Configure Storefront API access.
# ─────────────────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=30praum.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=

# Webhook secret usado por /api/revalidate (Shopify/Payload → invalida cache).
# Gerar com: openssl rand -hex 32
REVALIDATE_SECRET=change-me

# ─────────────────────────────────────────────────────────────
# Admin demo — Basic Auth no /admin/*
# Sem essas duas vars o /admin retorna 503 e fica inacessível
# (proteção padrão pra demo público).
# ─────────────────────────────────────────────────────────────
ADMIN_DEMO_USER=clara
ADMIN_DEMO_PASSWORD=
